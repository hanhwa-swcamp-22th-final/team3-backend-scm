<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ohgiraffers.team3backendscm.scm.query.mapper.EmployeeMapper">

    <!-- 직원 ID로 역량 티어 단건 조회 -->
    <select id="findTierById" parameterType="long" resultType="string">
        SELECT employee_tier
        FROM employee
        WHERE employee_id = #{employeeId}
    </select>

</mapper>
